# Privacy Shield — environment variable reference.
# Copy to `.env` (gitignored) and adjust. Compose reads this file automatically.

# ----- Backend (FastAPI) -----
# Required only for the Enhance tab. Leave empty to disable LLM calls.
OPENAI_API_KEY=

# Comma-separated list of allowed CORS origins. "*" only for local dev.
CORS_ORIGINS=*

# Mount the (placeholder) /convert route. Disabled by default.
ENABLE_CONVERT=false

# Folder containing prompt templates. In Docker this is the mount target.
PROMPTS_DIR=/app/prompts

# Python logging level: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO

# Container internal port (compose maps host 8088 → container 8000).
PORT=8000

# ----- Docker / Compose -----
# Image platform. Override to linux/amd64 if you're on amd64 or pulling x86 images.
DOCKER_PLATFORM=linux/arm64

# ----- Frontend (Vite) -----
# Build-time only. Leave empty in production (SPA served same-origin).
VITE_API_URL=

# Toggle the placeholder Convert tab. Default false.
VITE_FEATURE_CONVERT=false
